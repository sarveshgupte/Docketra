# =============================================================================
# Server & Application
# =============================================================================
PORT=5000
NODE_ENV=development
APP_NAME=Docketra

# =============================================================================
# Database
# =============================================================================
# Primary MongoDB connection string.
MONGO_URI=mongodb://127.0.0.1:27017/docketra
# Optional legacy alias supported by older scripts and deployments.
MONGODB_URI=mongodb://127.0.0.1:27017/docketra

# =============================================================================
# Frontend & CORS
# =============================================================================
FRONTEND_URL=https://app.example.com
FRONTEND_ORIGINS=https://app.example.com,https://admin.example.com
APP_ROOT_DOMAIN=example.com

# =============================================================================
# JWT & Authentication
# =============================================================================
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_PASSWORD_SETUP_SECRET=replace-with-a-separate-password-setup-secret
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# SuperAdmin Bootstrap (env-only; never store plaintext passwords)
# =============================================================================
SUPERADMIN_XID=X000001
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD_HASH=$2b$10$replace_this_with_a_real_bcrypt_hash_before_deploying
SUPERADMIN_OBJECT_ID=000000000000000000000001
SEED_ADMIN=false

# =============================================================================
# Email Delivery
# =============================================================================
BREVO_API_KEY=replace-with-your-brevo-api-key
MAIL_FROM="Docketra <noreply@example.com>"
# Optional legacy fallback if MAIL_FROM is not set.
SMTP_FROM=noreply@example.com

# =============================================================================
# Google Auth & External Storage
# =============================================================================
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/api/storage/google/callback
STORAGE_TOKEN_SECRET=replace-with-a-long-random-storage-token-secret
DISABLE_GOOGLE_AUTH=true
ENABLE_EXTERNAL_STORAGE=false

# =============================================================================
# Inbound Email
# =============================================================================
ENABLE_INBOUND_EMAIL=false
INBOUND_EMAIL_WEBHOOK_SECRET=replace-with-a-webhook-signing-secret
INBOUND_EMAIL_WEBHOOK_MAX_SKEW_SECONDS=300
INBOUND_EMAIL_REPLAY_CACHE_MAX=10000

# =============================================================================
# Encryption
# =============================================================================
# MASTER_ENCRYPTION_KEY should be base64 (44 chars) or hex (64 chars).
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-char-hex-key
# Optional legacy alias used by older local encryption paths.
MASTER_KEY=replace-with-32-byte-base64-or-64-char-hex-key
ENCRYPTION_PROVIDER=local
SECURITY_ENCRYPTION_KEY=replace-with-a-separate-32-byte-encryption-key

# =============================================================================
# Feature Flags
# =============================================================================
DISABLE_FILE_UPLOADS=false
DISABLE_FIRM_CREATION=false

# =============================================================================
# Redis
# =============================================================================
# Leave blank in development to use in-memory fallbacks.
REDIS_URL=redis://localhost:6379

# =============================================================================
# Security Rate Limits
# =============================================================================
SECURITY_RATE_LIMIT_GLOBAL=1000
SECURITY_RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_AUTH=100
SECURITY_RATE_LIMIT_AUTH_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_AUTH_BLOCK_SECONDS=300
SECURITY_RATE_LIMIT_TENANT_PER_MINUTE=1000
SECURITY_RATE_LIMIT_SENSITIVE=150
SECURITY_RATE_LIMIT_SENSITIVE_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_SIGNUP_PER_HOUR=100
SECURITY_RATE_LIMIT_SIGNUP_WINDOW_SECONDS=3600
SECURITY_RATE_LIMIT_SIGNUP_PER_EMAIL_PER_WINDOW=20
SECURITY_RATE_LIMIT_SIGNUP_OTP_MAX_RESENDS=10
SECURITY_RATE_LIMIT_LOGIN_PER_MINUTE=75
SECURITY_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_FORGOT_PASSWORD_PER_MINUTE=50
SECURITY_RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_PUBLIC_PER_MINUTE=500
SECURITY_RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_OTP_VERIFY_PER_MINUTE=30
SECURITY_RATE_LIMIT_OTP_VERIFY_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_OTP_VERIFY_BLOCK_SECONDS=60
SECURITY_RATE_LIMIT_OTP_RESEND_PER_MINUTE=10
SECURITY_RATE_LIMIT_OTP_RESEND_PER_EMAIL_PER_WINDOW=10
SECURITY_RATE_LIMIT_OTP_RESEND_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_OTP_RESEND_COOLDOWN_SECONDS=60
SECURITY_RATE_LIMIT_USER_READ_PER_MINUTE=300
SECURITY_RATE_LIMIT_USER_READ_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_USER_WRITE_PER_MINUTE=150
SECURITY_RATE_LIMIT_USER_WRITE_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_SEARCH_PER_MINUTE=150
SECURITY_RATE_LIMIT_SEARCH_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_PROFILE_PER_MINUTE=300
SECURITY_RATE_LIMIT_PROFILE_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_REFRESH_IP_PER_MINUTE=120
SECURITY_RATE_LIMIT_REFRESH_IP_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_REFRESH_USER_PER_WINDOW=1000
SECURITY_RATE_LIMIT_REFRESH_USER_WINDOW_SECONDS=86400
# Optional legacy alias still supported by the refresh-token limiter.
SECURITY_RATE_LIMIT_REFRESH_USER_PER_DAY=1000
SECURITY_RATE_LIMIT_SUPERADMIN_PER_MINUTE=300
SECURITY_RATE_LIMIT_SUPERADMIN_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_INTERNAL_METRICS_PER_MINUTE=300
SECURITY_RATE_LIMIT_INTERNAL_METRICS_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_CONTACT_PER_WINDOW=20
SECURITY_RATE_LIMIT_CONTACT_WINDOW_SECONDS=900
SECURITY_RATE_LIMIT_DEBUG_PER_MINUTE=30
SECURITY_RATE_LIMIT_DEBUG_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_INBOUND_EMAIL_PER_MINUTE=120
SECURITY_RATE_LIMIT_INBOUND_EMAIL_WINDOW_SECONDS=60
SECURITY_ACCOUNT_LOCK_ATTEMPTS=5
SECURITY_ACCOUNT_LOCK_SECONDS=1800

# =============================================================================
# File Uploads & Malware Scanning
# =============================================================================
SECURITY_UPLOAD_MAX_SIZE_MB=5
SECURITY_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
UPLOAD_SCAN_STRICT=false

# =============================================================================
# Internal Metrics & Runtime Tuning
# =============================================================================
METRICS_TOKEN=replace-with-a-long-random-internal-token
DB_LATENCY_THRESHOLD_MS=750
JSON_BODY_LIMIT=100kb
SOFT_DELETE_RETENTION_DAYS=90
RUN_ADMIN_HIERARCHY_MIGRATION_ON_START=false
ADMIN_BACKFILL_TIMEOUT_MS=30000

# =============================================================================
# Build Metadata (optional)
# =============================================================================
BUILD_VERSION=1.0.0
BUILD_TIMESTAMP=2026-01-01T00:00:00.000Z
# Optional legacy alias used if BUILD_TIMESTAMP is not set.
BUILD_TIME=2026-01-01T00:00:00.000Z
GIT_COMMIT=replace-with-git-sha

# =============================================================================
# Maintenance / Script Defaults
# =============================================================================
DEFAULT_FIRM_NAME=Example Firm
DRY_RUN=false

# =============================================================================
# Frontend Build Variables
# These may also be placed in ui/.env for the Vite app.
# =============================================================================
VITE_API_BASE_URL=/api
VITE_ENABLE_GOOGLE_LOGIN=false
VITE_INBOUND_EMAIL_DOMAIN=inbound.example.com
