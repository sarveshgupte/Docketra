# API Configuration
# 
# ⚠️ REQUIRED in all environments (development and production)
# Set this environment variable in your deployment platform's configuration
#
# Examples:
# Production (full URL):  VITE_API_BASE_URL=https://api.example.com/api
# Development (local):    VITE_API_BASE_URL=http://localhost:5000/api
# Development (proxy):    VITE_API_BASE_URL=/api
#
# Note: The value '/api' is proxied by vite.config.js to localhost:5000 in development
VITE_API_BASE_URL=http://localhost:5000/api

# Optional: explicit support email shown in dashboard help content.
# Safe for client-side exposure because VITE_ variables are bundled publicly.
VITE_SUPPORT_EMAIL=support@docketra.com

# Optional: production source maps remain disabled by default.
# Set to true only for controlled incident debugging workflows.
VITE_ENABLE_PROD_SOURCEMAPS=false
