{
  "name": "docketra",
  "version": "1.0.0",
  "description": "Task & Case Management System - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:worker": "node worker.js",
    "dev": "nodemon src/server.js",
    "build": "npm install --include=dev && cd ui && npm install --include=dev && npm run build",
    "lint": "find src tests -name '*.js' -print0 | xargs -0 -n1 node --check",
    "verify:build": "cd ui && npm run build",
    "build:ui": "cd ui && npm run build",
    "install:ui": "cd ui && npm install",
    "heroku-postbuild": "npm run install:ui && npm run build:ui",
    "test:integrity": "node tests/category.controller.test.js && node tests/adminIntegrity.test.js && node tests/firmRbac.test.js && node tests/writeSafety.test.js && node tests/requestLifecycle.test.js && node tests/sideEffectQueue.test.js && node tests/circuitBreaker.test.js && node tests/softDelete.test.js && node tests/caseStateMachine.test.js && node tests/caseSla.service.test.js && node tests/caseSlaConcurrency.test.js && node tests/diagnostics.service.test.js && node tests/migrationEncryptFields.test.js",
    "test:security": "node tests/securityHardening.test.js && node tests/coreSecurityHardeningPhase2.test.js",
    "test:hardening": "node tests/requestId.middleware.test.js && node tests/productionHardening.test.js",
    "test": "npm run test:integrity && npm run test:security && npm run test:hardening && node tests/fileUtils.test.js",
    "validate:env": "node -e \"process.env.NODE_ENV=process.env.NODE_ENV||'test'; process.env.JWT_SECRET=process.env.JWT_SECRET||'0123456789abcdef0123456789abcdef'; process.env.SUPERADMIN_PASSWORD_HASH=process.env.SUPERADMIN_PASSWORD_HASH||'\\$2b\\$10\\$abcdefghijklmnopqrstuu0Lz3M0RtZpmjHtkobaN6D2PfYZ7RUTy'; process.env.SUPERADMIN_XID=process.env.SUPERADMIN_XID||'X000001'; process.env.SUPERADMIN_EMAIL=process.env.SUPERADMIN_EMAIL||'superadmin@example.com'; process.env.SUPERADMIN_OBJECT_ID=process.env.SUPERADMIN_OBJECT_ID||'000000000000000000000001'; process.env.MONGO_URI=process.env.MONGO_URI||'mongodb://127.0.0.1:27017/docketra'; process.env.DISABLE_GOOGLE_AUTH=process.env.DISABLE_GOOGLE_AUTH||'true'; process.env.ENCRYPTION_PROVIDER=process.env.ENCRYPTION_PROVIDER||'disabled'; require('./src/config/validateEnv').validateEnv();\"",
    "migration:add_multi_tenant_indexes": "node scripts/migrations/add_multi_tenant_indexes.js up",
    "migration:rollback_multi_tenant_indexes": "node scripts/migrations/add_multi_tenant_indexes.js down",
    "migration:status_to_lowercase": "node src/scripts/migrateStatusToLowercase.js",
    "migration:add_starter_plan_fields": "node scripts/migrations/add_starter_plan_fields.js up",
    "migration:rollback_starter_plan_fields": "node scripts/migrations/add_starter_plan_fields.js down"
  },
  "keywords": [
    "task-management",
    "case-management",
    "api",
    "express",
    "mongodb"
  ],
  "engines": {
    "node": "18.x",
    "npm": ">=9.0.0"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.999.0",
    "@aws-sdk/s3-request-presigner": "^3.999.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^170.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mongoose": "^9.3.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.17.2",
    "rate-limit-redis": "^4.3.1",
    "speakeasy": "^2.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  },
  "overrides": {
    "tar": "^7.5.10"
  }
}
