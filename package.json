{
  "name": "docketra",
  "version": "1.0.0",
  "description": "Task & Case Management System - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:ui": "cd ui && npm run build",
    "install:ui": "cd ui && npm install",
    "heroku-postbuild": "npm run install:ui && npm run build:ui",
    "test:integrity": "node tests/adminIntegrity.test.js && node tests/firmRbac.test.js && node tests/writeSafety.test.js && node tests/requestLifecycle.test.js && node tests/sideEffectQueue.test.js && node tests/circuitBreaker.test.js && node tests/softDelete.test.js && node tests/caseStateMachine.test.js && node tests/caseSla.service.test.js && node tests/caseSlaConcurrency.test.js",
    "test:security": "node tests/securityHardening.test.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migration:add_multi_tenant_indexes": "node scripts/migrations/add_multi_tenant_indexes.js up",
    "migration:rollback_multi_tenant_indexes": "node scripts/migrations/add_multi_tenant_indexes.js down",
    "migration:status_to_lowercase": "node src/scripts/migrateStatusToLowercase.js",
    "migration:add_starter_plan_fields": "node scripts/migrations/add_starter_plan_fields.js up",
    "migration:rollback_starter_plan_fields": "node scripts/migrations/add_starter_plan_fields.js down"
  },
  "keywords": [
    "task-management",
    "case-management",
    "api",
    "express",
    "mongodb"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.999.0",
    "@aws-sdk/s3-request-presigner": "^3.999.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^170.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mongoose": "^9.1.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.17.2",
    "rate-limit-redis": "^4.3.1",
    "speakeasy": "^2.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
